<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="EtherealPDF.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:EtherealPDF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#131313">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" 
          Grid.Row="0" Grid.Column="1"
          Padding="48,0,0,0">

            <Grid.Background>
                <AcrylicBrush BackgroundSource="HostBackdrop" 
                          TintColor="#131313" 
                          TintOpacity="0.6" 
                          FallbackColor="#131313" />
            </Grid.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="180" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                       Text="ETHEREAL PDF" 
                       FontFamily="Manrope" 
                       FontSize="18" 
                       FontWeight="Black" 
                       Foreground="White" 
                       VerticalAlignment="Center" 
                       CharacterSpacing="50"/>

                <TextBox Grid.Column="1" 
                     PlaceholderText="Search your library..."
                     VerticalAlignment="Center"
                     MaxWidth="400"
                     Margin="48,0,0,0"
                     CornerRadius="9999"
                     Background="#1B1B1C"
                     BorderThickness="0"
                     Foreground="#E5E2E1"
                     Padding="40,10,20,10">
                </TextBox>

                <StackPanel Grid.Column="2" 
                        Orientation="Horizontal" 
                        Spacing="24" 
                        VerticalAlignment="Center">

                    <Button CornerRadius="12" 
                        Foreground="#001E2B" 
                        FontWeight="Bold" 
                        Padding="24,10">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#74D1FF" Offset="0.0" />
                                <GradientStop Color="#0080A8" Offset="1.0" />
                            </LinearGradientBrush>
                        </Button.Background>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14"/>
                            <TextBlock Text="Import PDF" FontSize="14" />
                        </StackPanel>
                    </Button>

                    <PersonPicture ProfilePicture="ms-appx:///Assets/Profile.png" 
                               Width="32" Height="32" />
                </StackPanel>
            </Grid>
        </Grid>

    </Grid>

</Window>