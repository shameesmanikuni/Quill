<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EtherealPDF.Pages.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:EtherealPDF.Pages"
    xmlns:models="using:EtherealPDF.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>

        <!-- ═══════════════════════════════════════════════════════════
             CONTINUE READING CARD  –  480 × 192 horizontal card
             Hover: background lightens + lifts 6 px
        ═══════════════════════════════════════════════════════════ -->
        <Style x:Key="ContinueReadingCardStyle" TargetType="Button">
            <Setter Property="Width"                    Value="480"/>
            <Setter Property="Height"                   Value="192"/>
            <Setter Property="CornerRadius"             Value="16"/>
            <Setter Property="Padding"                  Value="0"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment"   Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="RootGrid" CornerRadius="16"
                              RenderTransformOrigin="0.5,1">
                            <Grid.Background>
                                <SolidColorBrush x:Name="CardBg" Color="#202020"/>
                            </Grid.Background>
                            <Grid.RenderTransform>
                                <TranslateTransform x:Name="CardLift"/>
                            </Grid.RenderTransform>
                            <Grid.Shadow>
                                <ThemeShadow/>
                            </Grid.Shadow>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="CardLift"
                                                Storyboard.TargetProperty="Y"
                                                To="0" Duration="0:0:0.2"/>
                                            <ColorAnimation
                                                Storyboard.TargetName="CardBg"
                                                Storyboard.TargetProperty="Color"
                                                To="#202020" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="CardLift"
                                                Storyboard.TargetProperty="Y"
                                                To="-6" Duration="0:0:0.2"/>
                                            <ColorAnimation
                                                Storyboard.TargetName="CardBg"
                                                Storyboard.TargetProperty="Color"
                                                To="#2A2A2A" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="CardLift"
                                                Storyboard.TargetProperty="Y"
                                                To="-2" Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <ContentPresenter
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             LIBRARY CARD  –  vertical card (fills UniformGridLayout cell)
             Hover: background lightens + lifts 6 px
        ═══════════════════════════════════════════════════════════ -->
        <Style x:Key="LibraryCardStyle" TargetType="Button">
            <Setter Property="Padding"                  Value="0"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="HorizontalAlignment"      Value="Stretch"/>
            <Setter Property="VerticalAlignment"        Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment"   Value="Top"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="RootGrid"
                              RenderTransformOrigin="0.5,1">
                            <Grid.Background>
                                <SolidColorBrush x:Name="CardBg" Color="Transparent"/>
                            </Grid.Background>
                            <Grid.RenderTransform>
                                <TranslateTransform x:Name="CardLift"/>
                            </Grid.RenderTransform>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="CardLift"
                                                Storyboard.TargetProperty="Y"
                                                To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="CardLift"
                                                Storyboard.TargetProperty="Y"
                                                To="-8" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="CardLift"
                                                Storyboard.TargetProperty="Y"
                                                To="-2" Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <ContentPresenter
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Top"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             ARROW BUTTON  –  circular, semi-transparent
        ═══════════════════════════════════════════════════════════ -->
        <Style x:Key="ArrowButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="48"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="CornerRadius"    Value="24"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="RootGrid" CornerRadius="24">
                            <Grid.Background>
                                <SolidColorBrush x:Name="ArrowBg" Color="#CC2A2A2A"/>
                            </Grid.Background>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="ArrowBg"
                                                Storyboard.TargetProperty="Color"
                                                To="#EE353535" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="ArrowBg"
                                                Storyboard.TargetProperty="Color"
                                                To="#BB2A2A2A" Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             ICON ACTION BUTTON  –  small square (filter / grid-view)
        ═══════════════════════════════════════════════════════════ -->
        <Style x:Key="IconActionButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="40"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="#1B1C1C"/>
            <Setter Property="Foreground"      Value="#889299"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="RootGrid" CornerRadius="8">
                            <Grid.Background>
                                <SolidColorBrush x:Name="Bg" Color="#1B1C1C"/>
                            </Grid.Background>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Bg"
                                                Storyboard.TargetProperty="Color"
                                                To="#202020" Duration="0:0:0.1"/>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="ContentPresenter"
                                                Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <SolidColorBrush Color="#E5E2E1"/>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="ContentPresenter"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <!-- ─────────────────────────────────────────────────────────────────
         ROOT SCROLL – main content area
    ───────────────────────────────────────────────────────────────────── -->
    <ScrollViewer
        VerticalScrollMode="Enabled"
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollMode="Disabled">

        <StackPanel Padding="48,128,48,80" Spacing="72">

            <!-- ═══════════════════════════════════════════════════════════
                 CONTINUE READING SECTION
            ═══════════════════════════════════════════════════════════ -->
            <Grid x:Name="ContinueReadingSection"
                  PointerEntered="ContinueReadingSection_PointerEntered"
                  PointerExited="ContinueReadingSection_PointerExited">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0">
                    <TextBlock
                        Text="Continue Reading"
                        FontFamily="{StaticResource ManropeFont}"
                        FontSize="36"
                        FontWeight="ExtraBold"
                        Foreground="White"
                        VerticalAlignment="Center"/>
                    <HyperlinkButton
                        Content="View all history"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Foreground="#75D1FF"
                        FontSize="13"
                        FontFamily="{StaticResource InterFont}"/>
                </Grid>

                <!-- ── EMPTY STATE ──────────────────────────────────────────── -->
                <Border Grid.Row="2"
                        Visibility="{x:Bind ViewModel.EmptyRecentBooksVisibility, Mode=OneWay}"
                        Padding="48,0,48,56">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                        <FontIcon
                            FontFamily="{StaticResource SymbolFont}"
                            Glyph="&#xEA19;" FontSize="48"
                            Foreground="#303840"
                            HorizontalAlignment="Center"/>
                        <TextBlock
                            Text="No books in progress yet"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="#505860"
                            HorizontalAlignment="Center"
                            FontFamily="{StaticResource ManropeFont}"/>
                        <TextBlock
                            Text="Import a book and start your reading journey"
                            FontSize="13"
                            Foreground="#383E46"
                            HorizontalAlignment="Center"
                            FontFamily="{StaticResource InterFont}"/>
                    </StackPanel>
                </Border>

                <!-- ── BOOKS + ARROWS ──────────────────────────────────────── -->
                <Grid Grid.Row="2"
                      Visibility="{x:Bind ViewModel.RecentBooksVisibility, Mode=OneWay}">

                    <!-- Horizontal scroll of wide cards -->
                    <ScrollViewer
                        x:Name="ContinueReadingScroll"
                        HorizontalScrollMode="Enabled"
                        VerticalScrollMode="Disabled"
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Hidden"
                        ViewChanged="ContinueReadingScroll_ViewChanged">

                        <ItemsRepeater
                            ItemsSource="{x:Bind ViewModel.RecentBooks, Mode=OneWay}"
                            Margin="0,0,0,12">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="32"/>
                            </ItemsRepeater.Layout>
                            <DataTemplate x:DataType="models:Book">
                                <!-- Wide Continue Reading Card -->
                                <Button Style="{StaticResource ContinueReadingCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Cover (left 1/3) -->
                                        <Grid Grid.Column="0">
                                            <!-- Gradient placeholder -->
                                            <Border CornerRadius="16,0,0,16"
                                                    Visibility="{x:Bind PlaceholderVisibility, Mode=OneWay}">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#5127AD" Offset="0.0"/>
                                                        <GradientStop Color="#0080A8" Offset="1.0"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <!-- Actual cover via ImageBrush (clips to CornerRadius) -->
                                            <Border CornerRadius="16,0,0,16"
                                                    Visibility="{x:Bind CoverVisibility, Mode=OneWay}">
                                                <Border.Background>
                                                    <ImageBrush
                                                        ImageSource="{x:Bind CoverImage, Mode=OneWay}"
                                                        Stretch="UniformToFill"/>
                                                </Border.Background>
                                            </Border>
                                        </Grid>

                                        <!-- Text content (right 2/3) -->
                                        <Grid Grid.Column="1" Padding="24,24,24,24">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Title + Author -->
                                            <StackPanel Grid.Row="0" Spacing="6" VerticalAlignment="Top">
                                                <TextBlock
                                                    Text="{x:Bind Title, Mode=OneWay}"
                                                    FontSize="17"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    FontFamily="{StaticResource ManropeFont}"
                                                    MaxLines="2"
                                                    TextWrapping="Wrap"
                                                    TextTrimming="WordEllipsis"/>
                                                <TextBlock
                                                    Text="{x:Bind Author, Mode=OneWay}"
                                                    FontSize="13"
                                                    Foreground="#889299"
                                                    FontFamily="{StaticResource InterFont}"/>
                                            </StackPanel>

                                            <!-- Progress -->
                                            <StackPanel Grid.Row="1" Spacing="8">
                                                <Grid>
                                                    <TextBlock
                                                        Text="{x:Bind ReadingProgressText, Mode=OneWay}"
                                                        FontSize="12"
                                                        FontWeight="Bold"
                                                        Foreground="#75D1FF"
                                                        FontFamily="{StaticResource InterFont}"
                                                        VerticalAlignment="Bottom"/>
                                                    <TextBlock
                                                        Text="{x:Bind PageProgressText, Mode=OneWay}"
                                                        FontSize="11"
                                                        Foreground="#889299"
                                                        FontFamily="{StaticResource InterFont}"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Bottom"/>
                                                </Grid>
                                                <ProgressBar
                                                    Value="{x:Bind LastPageRead, Mode=OneWay}"
                                                    Maximum="{x:Bind DisplayTotalPages, Mode=OneWay}"
                                                    Height="8"
                                                    CornerRadius="4">
                                                    <ProgressBar.Resources>
                                                        <SolidColorBrush
                                                            x:Key="ProgressBarIndicatorBackground"
                                                            Color="#75D1FF"/>
                                                        <SolidColorBrush
                                                            x:Key="ProgressBarTrackBackground"
                                                            Color="#0E0E0E"/>
                                                    </ProgressBar.Resources>
                                                </ProgressBar>
                                            </StackPanel>
                                        </Grid>

                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>

                    <!-- LEFT arrow -->
                    <Button
                        x:Name="LeftArrowBtn"
                        Style="{StaticResource ArrowButtonStyle}"
                        Visibility="{x:Bind ViewModel.ArrowsVisibility, Mode=OneWay}"
                        Opacity="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="-20,0,0,0"
                        Click="LeftArrow_Click">
                        <FontIcon
                            FontFamily="{StaticResource SymbolFont}"
                            Glyph="&#xE5CB;"
                            FontSize="22"/>
                    </Button>

                    <!-- RIGHT arrow -->
                    <Button
                        x:Name="RightArrowBtn"
                        Style="{StaticResource ArrowButtonStyle}"
                        Visibility="{x:Bind ViewModel.ArrowsVisibility, Mode=OneWay}"
                        Opacity="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,-20,0"
                        Click="RightArrow_Click">
                        <FontIcon
                            FontFamily="{StaticResource SymbolFont}"
                            Glyph="&#xE5CC;"
                            FontSize="22"/>
                    </Button>

                </Grid>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════
                 MY LIBRARY SECTION
            ═══════════════════════════════════════════════════════════ -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0">
                    <TextBlock
                        Text="My Library"
                        FontFamily="{StaticResource ManropeFont}"
                        FontSize="30"
                        FontWeight="ExtraBold"
                        Foreground="White"
                        VerticalAlignment="Center"/>
                    <StackPanel
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="12">
                        <Button Style="{StaticResource IconActionButtonStyle}">
                            <FontIcon
                                FontFamily="{StaticResource SymbolFont}"
                                Glyph="&#xE152;"
                                FontSize="18"/>
                        </Button>
                        <Button Style="{StaticResource IconActionButtonStyle}">
                            <FontIcon
                                FontFamily="{StaticResource SymbolFont}"
                                Glyph="&#xE9B0;"
                                FontSize="18"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- ── EMPTY STATE ──────────────────────────────────────────── -->
                <Border Grid.Row="2"
                        Visibility="{x:Bind ViewModel.EmptyBooksVisibility, Mode=OneWay}"
                        Padding="48,0,48,96">
                    <StackPanel HorizontalAlignment="Center" Spacing="20">
                        <FontIcon
                            FontFamily="{StaticResource SymbolFont}"
                            Glyph="&#xE02F;"
                            FontSize="64"
                            Foreground="#303840"
                            HorizontalAlignment="Center"/>
                        <TextBlock
                            Text="Your library is empty"
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="#505860"
                            HorizontalAlignment="Center"
                            FontFamily="{StaticResource ManropeFont}"/>
                        <TextBlock
                            Text="Click &#x2018;Import&#x2019; in the top bar to add your first book"
                            FontSize="14"
                            Foreground="#383E46"
                            HorizontalAlignment="Center"
                            FontFamily="{StaticResource InterFont}"/>
                    </StackPanel>
                </Border>

                <!-- ── LIBRARY GRID ─────────────────────────────────────────── -->
                <ItemsRepeater
                    Grid.Row="2"
                    x:Name="LibraryGrid"
                    ItemsSource="{x:Bind ViewModel.AllBooks, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.BooksGridVisibility, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout
                            MinItemWidth="175"
                            MinItemHeight="320"
                            MinColumnSpacing="32"
                            MinRowSpacing="48"
                            ItemsStretch="Fill"/>
                    </ItemsRepeater.Layout>

                    <DataTemplate x:DataType="models:Book">
                        <!-- Vertical Library Card -->
                        <Button Style="{StaticResource LibraryCardStyle}">
                            <StackPanel Spacing="0">

                                <!-- Cover (3:4 ratio via fixed height) -->
                                <Grid Height="230">
                                    <!-- Gradient placeholder -->
                                    <Border CornerRadius="12"
                                            Visibility="{x:Bind PlaceholderVisibility, Mode=OneWay}">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#1A2D5A" Offset="0.0"/>
                                                <GradientStop Color="#5127AD" Offset="0.6"/>
                                                <GradientStop Color="#0080A8" Offset="1.0"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <!-- Book title initial centred -->
                                        <TextBlock
                                            Text="{x:Bind Title, Mode=OneWay}"
                                            FontFamily="{StaticResource ManropeFont}"
                                            FontSize="52"
                                            FontWeight="ExtraBold"
                                            Foreground="#20FFFFFF"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            MaxLines="1"
                                            TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                    <!-- Actual cover -->
                                    <Border CornerRadius="12"
                                            Visibility="{x:Bind CoverVisibility, Mode=OneWay}">
                                        <Border.Background>
                                            <ImageBrush
                                                ImageSource="{x:Bind CoverImage, Mode=OneWay}"
                                                Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>
                                </Grid>

                                <!-- Text info below cover -->
                                <StackPanel Padding="0,14,0,0" Spacing="6">
                                    <TextBlock
                                        Text="{x:Bind Title, Mode=OneWay}"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Foreground="#E5E2E1"
                                        FontFamily="{StaticResource InterFont}"
                                        MaxLines="2"
                                        TextWrapping="Wrap"
                                        TextTrimming="WordEllipsis"/>

                                    <Grid Margin="0,2,0,0">
                                        <TextBlock
                                            Text="{x:Bind ReadingProgressText, Mode=OneWay}"
                                            FontSize="11"
                                            Foreground="#889299"
                                            FontFamily="{StaticResource InterFont}"/>
                                        <TextBlock
                                            Text="{x:Bind PageProgressText, Mode=OneWay}"
                                            FontSize="11"
                                            Foreground="#889299"
                                            FontFamily="{StaticResource InterFont}"
                                            HorizontalAlignment="Right"/>
                                    </Grid>

                                    <ProgressBar
                                        Value="{x:Bind LastPageRead, Mode=OneWay}"
                                        Maximum="{x:Bind DisplayTotalPages, Mode=OneWay}"
                                        Height="4"
                                        CornerRadius="2"
                                        Margin="0,2,0,0">
                                        <ProgressBar.Resources>
                                            <SolidColorBrush
                                                x:Key="ProgressBarIndicatorBackground"
                                                Color="#5127AD"/>
                                            <SolidColorBrush
                                                x:Key="ProgressBarTrackBackground"
                                                Color="#0E0E0E"/>
                                        </ProgressBar.Resources>
                                    </ProgressBar>
                                </StackPanel>

                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsRepeater>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
